generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}
// Admin-only categorization for readings
enum ReadingCategory {
  LOVE
  MARRIAGE
  WORK
  LIFESTYLE
  SPIRITUAL
  EDUCATION
  HEALTH
  MONEY
}

// Supported religions for spiritual guidance
enum Religion {
  BUDDHIST
  HINDU
  CHRISTIAN
  ISLAM
}

// Zodiac signs for admin-authored horoscope-like readings
enum ZodiacSign {
  ARIES
  TAURUS
  GEMINI
  CANCER
  LEO
  VIRGO
  LIBRA
  SCORPIO
  SAGITTARIUS
  CAPRICORN
  AQUARIUS
  PISCES
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  // Phone login support: store country/student code separately from local number
  // phoneCode should be digits-only (e.g., 95) and phoneNumber without leading 0
  phoneCode    String?
  phoneNumber  String?
  passwordHash String
  name         String
  avatar       String?
  role         Role     @default(USER)
  dailyLimit   Int      @default(3)
  extraQuota   Int      @default(0)
  gender       Gender?
  age          Int?
  createdAt    DateTime @default(now())
  readings     Reading[]
  zodiacViews  ZodiacView[]
  zodiacReactions ZodiacReaction[]
  guidances    Guidance[]
  goodDeeds   GoodDeed[]
  natalRecords NatalReadingRecord[]

  @@unique([phoneCode, phoneNumber])
}

model Reading {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  question  String
  cards     Json
  answer    String
  language  String   @default("my")
  category  ReadingCategory?
  createdAt DateTime @default(now())
  @@index([userId, createdAt])
}

// Admin-authored zodiac readings by timeframe
model ZodiacReading {
  id         String     @id @default(cuid())
  sign       ZodiacSign
  startDate  DateTime
  endDate    DateTime
  cards      Json
  fakeReactions Int     @default(0)
  // Burmese professional tone sections
  general      String
  relationship String // love, family, society
  workMoney    String
  health       String
  education    String
  warnings     String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([sign, createdAt])
  views      ZodiacView[]
  reactions  ZodiacReaction[]
}

// Track which users viewed which zodiac reading, and how often
model ZodiacView {
  id         String         @id @default(cuid())
  reading    ZodiacReading  @relation(fields: [readingId], references: [id])
  readingId  String
  user       User           @relation(fields: [userId], references: [id])
  userId     String
  count      Int            @default(0)
  lastViewed DateTime       @default(now())

  @@unique([readingId, userId])
  @@index([readingId])
}

// Per-user reaction (heart) on a zodiac reading
model ZodiacReaction {
  id        String        @id @default(cuid())
  reading   ZodiacReading @relation(fields: [readingId], references: [id])
  readingId String
  user      User          @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime      @default(now())

  @@unique([readingId, userId])
  @@index([readingId])
}

// Spiritual guidance entries generated via AI based on selected religion
model Guidance {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  religion  Religion
  question  String
  answer    String
  references Json?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
}

enum GoodDeedCategory {
  FAMILY
  COMMUNITY
  RELIGION
  SELF_GROWTH
  HEALTH
  FINANCIAL
  EDUCATION
  ENVIRONMENT
  KINDNESS
  PROFESSIONAL
}

enum GoodDeedBelief {
  BUDDHIST
  HINDU
  CHRISTIAN
  ISLAM
  ATHEIST
}

model GoodDeed {
  id         String            @id @default(cuid())
  user       User              @relation(fields: [userId], references: [id])
  userId     String
  deedDate   DateTime
  note       String
  categories GoodDeedCategory[]
  aiFeedback String
  language   String            @default("my")
  belief     GoodDeedBelief    @default(ATHEIST)
  points     Int               @default(0)
  createdAt  DateTime          @default(now())

  @@index([userId, deedDate])
}

model NatalReadingRecord {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  context   String
  phase     String?
  language  String
  request   Json
  response  Json
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
